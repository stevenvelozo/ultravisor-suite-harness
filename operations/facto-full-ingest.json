					{ "Hash": "parse-file-Error", "Direction": "output", "Side": "bottom", "Label": "Error" },
					{ "Hash": "parse-file-Result", "Direction": "output", "Side": "right-top", "Label": "Result" }
				],
				"Data": {
					"FilePath": "{~D:Record.Operation.FilePath~}",
					"Format": "{~D:Record.Operation.FileFormat~}"
				}
			},
			{
				"Hash": "create-source",
				"Type": "beacon-factodata-createsource",
				"X": 530,
				"Y": 180,
				"Width": 220,
				"Height": 120,
				"Title": "Create Source",
