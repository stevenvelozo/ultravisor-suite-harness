{
	"Hash": "facto-full-ingest",
	"Name": "Full Pipeline Ingest",
	"Description": "End-to-end data ingest: parse file via meadow-integration beacon, create Facto entities, and bulk-store records via Facto beacon. Parameters: DatasetName, FilePath, FileFormat.",
	"Tags": ["facto", "ingest", "beacon", "meadow-integration", "full-pipeline"],
	"Author": "Ultravisor",
	"Version": "1.0.0",
	"Graph": {
