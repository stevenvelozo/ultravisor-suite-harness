				],
				"Data": {
					"Message": "Full pipeline ingest encountered an error."
				}
			},
			{
				"Hash": "end",
				"Type": "end",
				"X": 1970,
				"Y": 200,
				"Width": 140,
				"Height": 80,
				"Title": "End",
				"Ports": [
					{ "Hash": "end-in", "Direction": "input", "Side": "left-bottom", "Label": "In" }
				],
				"Data": {}
			}
		],
