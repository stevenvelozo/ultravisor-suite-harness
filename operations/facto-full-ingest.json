				}
			},
			{
				"Hash": "bulk-create",
				"Type": "beacon-factodata-bulkcreaterecords",
				"X": 1370,
				"Y": 180,
				"Width": 240,
				"Height": 120,
				"Title": "Bulk Create Records",
