			{ "SourceNodeHash": "create-job",      "SourcePortHash": "create-job-Complete",     "TargetNodeHash": "bulk-create",    "TargetPortHash": "bulk-create-Trigger" },
			{ "SourceNodeHash": "create-job",      "SourcePortHash": "create-job-Error",        "TargetNodeHash": "error-handler",  "TargetPortHash": "error-handler-Execute" },
			{ "SourceNodeHash": "bulk-create",     "SourcePortHash": "bulk-create-Complete",    "TargetNodeHash": "update-job",     "TargetPortHash": "update-job-Trigger" },
			{ "SourceNodeHash": "bulk-create",     "SourcePortHash": "bulk-create-Error",       "TargetNodeHash": "error-handler",  "TargetPortHash": "error-handler-Execute" },
			{ "SourceNodeHash": "update-job",      "SourcePortHash": "update-job-Complete",     "TargetNodeHash": "end",            "TargetPortHash": "end-in" },
			{ "SourceNodeHash": "update-job",      "SourcePortHash": "update-job-Error",        "TargetNodeHash": "error-handler",  "TargetPortHash": "error-handler-Execute" },
			{ "SourceNodeHash": "error-handler",   "SourcePortHash": "error-handler-Complete",  "TargetNodeHash": "end",            "TargetPortHash": "end-in" }
